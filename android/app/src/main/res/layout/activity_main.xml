<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|center_horizontal"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:text="@string/status_sdk_initializing"
            android:textSize="16sp" />

        <!-- Live MTA Alerts section (FEAT-03) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/live_section_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Configure Commute button (FEAT-07) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/configureCommuteButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/button_configure_commute" />

        <!-- Polling Settings button (FEAT-08) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/pollingSettingsButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/button_polling_settings" />

        <!-- Manual fetch group: direction toggle + Fetch Live (FEAT-14) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline"
            app:cardCornerRadius="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="@string/label_manual_fetch_direction"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <!-- Direction toggle (FEAT-07) -->
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/directionToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToWork"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/direction_to_work" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToHome"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/direction_to_home" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <Button
                    android:id="@+id/fetchLiveButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/live_fetch_button" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Auto-polling direction status (FEAT-14) -->
        <TextView
            android:id="@+id/autoPollingDirectionTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:minHeight="80dp">

            <TextView
                android:id="@+id/resultsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </ScrollView>

        <TextView
            android:id="@+id/apiUsageTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textAlignment="center"
            android:text="API usage: 0/50 today" />

    </LinearLayout>

    <!-- Debug test payload menu button — discrete bottom-right corner -->
    <Button
        android:id="@+id/debugMenuButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        android:text="⋮"
        android:textSize="20sp"
        android:alpha="0.35"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp" />

</FrameLayout>
